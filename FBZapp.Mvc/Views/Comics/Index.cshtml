@model FBZapp.Mvc.Models.ComicSearchViewModel

@{
    ViewBag.Title = "Comic Search";
}

<h2>Comic Search</h2>
<p>Loaded comics count: @ViewBag.LoadedCount</p>
<p>Showing first 100 results only.</p>
<p>@Html.ActionLink("Go to Advanced Search", "AdvancedSearch", "Comics")</p>

@using (Html.BeginForm("Index", "Comics", FormMethod.Get))
{
    <div>
        <label>Title Search</label>
        @Html.TextBoxFor(m => m.Query)
    </div>

    <div>
        <label>Genre</label>
        @Html.DropDownListFor(m => m.Genre,
            new SelectList(new[]
            {
                "",
                "Fantasy",
                "Horror",
                "Science Fiction"
            }))
    </div>

    <div>
        <label>Sort</label>
        @Html.DropDownListFor(m => m.SortOption,
            new SelectList(new[]
            {
                "",
                "A-Z",
                "Z-A"
            }))
    </div>

    <div>
        <label>Group By</label>
        @Html.DropDownListFor(m => m.GroupBy,
            new SelectList(new[]
            {
                "",
                "Author",
                "Year"
            }))
    </div>

    <div style="margin-top:10px;">
        <input type="submit" value="Search" />
    </div>
}

@if (Session["UserId"] != null)
{
    if (!string.IsNullOrWhiteSpace(Model.Query) ||
        !string.IsNullOrWhiteSpace(Model.Genre) ||
        !string.IsNullOrWhiteSpace(Model.SortOption))
    {
        using (Html.BeginForm("SaveSearch", "Saved", FormMethod.Post))
        {
            @Html.Hidden("queryText", Model.Query)
            @Html.Hidden("genre", Model.Genre)
            @Html.Hidden("sortOption", Model.SortOption)

            <div style="margin-top:10px;">
                <input type="submit" value="Save This Search" />
            </div>
        }
    }
}
else
{
    <p>Login to save search results.</p>
}


<hr />

@if (Model.Results != null && Model.Results.Count > 0)
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Genre</th>
                <th>Publisher</th>
                <th>Details</th>
                <th>Save</th>
                <th>Flag</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var comic in Model.Results)
            {
                <tr>
                    <td>
                        @(string.IsNullOrWhiteSpace(comic.Title)
        ? ""
        : comic.Title.Length > 100
            ? comic.Title.Substring(0, 100) + "..."
            : comic.Title)
                    </td>
                    <td>@comic.Author</td>
                    <td>@comic.Genre</td>
                    <td>@comic.Publisher</td>
                    <td>@Html.ActionLink("View", "Details", "Comics", new { title = comic.Title }, null)</td>
                    <td>
                        @if (Session["UserId"] != null)
                        {
                            using (Html.BeginForm("SaveComic", "Saved", FormMethod.Post))
                            {
                                @Html.Hidden("comicTitle", comic.Title)
                                <input type="submit" value="Save" />
                            }
                        }
                        else
                        {
                            <span>Login to save</span>
                        }
                    </td>
                    <td>
                        @if (Session["Role"] != null && Session["Role"].ToString() == "Staff")
                        {
                            using (Html.BeginForm("FlagComic", "Staff", FormMethod.Post))
                            {
                                @Html.Hidden("comicTitle", comic.Title)
                                @Html.Hidden("flagReason", "Flagged by staff user")
                                <input type="submit" value="Flag" />
                            }
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No comics found.</p>
}
