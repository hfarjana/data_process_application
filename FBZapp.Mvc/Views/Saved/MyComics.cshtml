@model List<FBZapp.Domain.Entities.SavedComic>

@{
    ViewBag.Title = "My Saved Comics";
}

<h2>My Saved Comics</h2>

@if (Model != null && Model.Count > 0)
{
    <table class="table">
        <thead>
            <tr>
                <th>Comic Title</th>
                <th>Saved Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ComicTitle</td>
                    <td>@item.SavedDate</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No saved comics yet.</p>
}