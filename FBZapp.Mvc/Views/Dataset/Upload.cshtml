@model FBZapp.Mvc.Models.DatasetUploadViewModel

@{
    ViewBag.Title = "Upload Dataset";
}

<h2>Upload New Dataset</h2>

@using (Html.BeginForm("Upload", "Dataset", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    <div>
        <label>Select CSV File</label>
        <input type="file" name="CsvFile" />
    </div>

    <div style="margin-top:10px;">
        <input type="submit" value="Upload Dataset" />
    </div>
}

@if (ViewBag.Message != null)
{
    <p>@ViewBag.Message</p>
}