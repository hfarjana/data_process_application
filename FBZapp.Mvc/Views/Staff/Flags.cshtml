@model List<FBZapp.Domain.Entities.FlaggedRecord>

@{
    ViewBag.Title = "Flagged Records";
}

<h2>Flagged Records</h2>
<p>The Flags view is loading successfully.</p>

@if (Model != null && Model.Count > 0)
{
    <table class="table">
        <thead>
            <tr>
                <th>Comic Title</th>
                <th>Reason</th>
                <th>Flagged By User ID</th>
                <th>Flagged Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ComicTitle</td>
                    <td>@item.FlagReason</td>
                    <td>@item.FlaggedByUserId</td>
                    <td>@item.FlaggedDate</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No flagged records yet.</p>
}
